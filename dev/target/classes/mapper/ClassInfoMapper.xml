<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.archive.mapper.ClassInfoMapper">

    <resultMap id="BaseResultMap" type="com.student.archive.entity.ClassInfo">
        <id column="pk_class" property="pkClass"/>
        <result column="major_id" property="majorId"/>
        <result column="class_name" property="className"/>
        <result column="grade" property="grade"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM class_info WHERE pk_class = #{pkClass}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM class_info
    </select>

    <select id="selectByMajorId" resultMap="BaseResultMap">
        SELECT * FROM class_info WHERE major_id = #{majorId}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM class_info
        <where>
            <if test="className != null and className != ''">
                AND class_name LIKE CONCAT('%', #{className}, '%')
            </if>
            <if test="majorId != null">
                AND major_id = #{majorId}
            </if>
            <if test="grade != null and grade != ''">
                AND grade = #{grade}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="pkClass">
        INSERT INTO class_info (major_id, class_name, grade) VALUES (#{majorId}, #{className}, #{grade})
    </insert>

    <update id="update">
        UPDATE class_info
        <set>
            <if test="majorId != null">major_id = #{majorId},</if>
            <if test="className != null">class_name = #{className},</if>
            <if test="grade != null">grade = #{grade},</if>
        </set>
        WHERE pk_class = #{pkClass}
    </update>

    <delete id="deleteById">
        DELETE FROM class_info WHERE pk_class = #{pkClass}
    </delete>
</mapper>

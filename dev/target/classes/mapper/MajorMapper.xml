<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.archive.mapper.MajorMapper">

    <resultMap id="BaseResultMap" type="com.student.archive.entity.Major">
        <id column="pk_major" property="pkMajor"/>
        <result column="college_id" property="collegeId"/>
        <result column="major_name" property="majorName"/>
        <result column="major_code" property="majorCode"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM major WHERE pk_major = #{pkMajor}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM major
    </select>

    <select id="selectByCollegeId" resultMap="BaseResultMap">
        SELECT * FROM major WHERE college_id = #{collegeId}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM major
        <where>
            <if test="majorName != null and majorName != ''">
                AND major_name LIKE CONCAT('%', #{majorName}, '%')
            </if>
            <if test="collegeId != null">
                AND college_id = #{collegeId}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="pkMajor">
        INSERT INTO major (college_id, major_name, major_code) VALUES (#{collegeId}, #{majorName}, #{majorCode})
    </insert>

    <update id="update">
        UPDATE major
        <set>
            <if test="collegeId != null">college_id = #{collegeId},</if>
            <if test="majorName != null">major_name = #{majorName},</if>
            <if test="majorCode != null">major_code = #{majorCode},</if>
        </set>
        WHERE pk_major = #{pkMajor}
    </update>

    <delete id="deleteById">
        DELETE FROM major WHERE pk_major = #{pkMajor}
    </delete>
</mapper>

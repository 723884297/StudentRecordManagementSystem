<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.archive.mapper.SysRoleMapper">

    <resultMap id="BaseResultMap" type="com.student.archive.entity.SysRole">
        <id column="pk_role" property="pkRole"/>
        <result column="role_name" property="roleName"/>
        <result column="role_code" property="roleCode"/>
        <result column="description" property="description"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM sys_role WHERE pk_role = #{pkRole}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM sys_role
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT r.* FROM sys_role r
        INNER JOIN sys_user_role ur ON r.pk_role = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="pkRole">
        INSERT INTO sys_role (role_name, role_code, description)
        VALUES (#{roleName}, #{roleCode}, #{description})
    </insert>

    <update id="update">
        UPDATE sys_role
        <set>
            <if test="roleName != null">role_name = #{roleName},</if>
            <if test="roleCode != null">role_code = #{roleCode},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE pk_role = #{pkRole}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role WHERE pk_role = #{pkRole}
    </delete>
</mapper>

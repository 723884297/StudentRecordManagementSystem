<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.archive.mapper.ArchiveFileMapper">

    <resultMap id="BaseResultMap" type="com.student.archive.entity.ArchiveFile">
        <id column="pk_archive_file" property="pkArchiveFile"/>
        <result column="student_id" property="studentId"/>
        <result column="category_id" property="categoryId"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="upload_user_id" property="uploadUserId"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="audit_user_id" property="auditUserId"/>
        <result column="audit_time" property="auditTime"/>
        <result column="audit_remark" property="auditRemark"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM archive_file WHERE pk_archive_file = #{pkArchiveFile}
    </select>

    <select id="selectByStudentId" resultMap="BaseResultMap">
        SELECT * FROM archive_file WHERE student_id = #{studentId} ORDER BY upload_time DESC
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM archive_file
        <where>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY upload_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="pkArchiveFile">
        INSERT INTO archive_file (student_id, category_id, file_name, file_path, file_size,
            description, status, upload_user_id)
        VALUES (#{studentId}, #{categoryId}, #{fileName}, #{filePath}, #{fileSize},
            #{description}, #{status}, #{uploadUserId})
    </insert>

    <update id="update">
        UPDATE archive_file
        <set>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE pk_archive_file = #{pkArchiveFile}
    </update>

    <delete id="deleteById">
        DELETE FROM archive_file WHERE pk_archive_file = #{pkArchiveFile}
    </delete>

    <update id="updateStatus">
        UPDATE archive_file
        SET status = #{status}, audit_user_id = #{auditUserId}, audit_time = NOW(), audit_remark = #{auditRemark}
        WHERE pk_archive_file = #{pkArchiveFile}
    </update>

    <select id="countTotal" resultType="int">
        SELECT COUNT(*) FROM archive_file
    </select>

    <select id="countByStatus" resultType="int">
        SELECT COUNT(*) FROM archive_file WHERE status = #{status}
    </select>
</mapper>

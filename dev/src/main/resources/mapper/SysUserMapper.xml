<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.archive.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.student.archive.entity.SysUser">
        <id column="pk_user" property="pkUser"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE pk_user = #{pkUser}
    </select>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name LIKE CONCAT('%', #{realName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="pkUser">
        INSERT INTO sys_user (username, password, real_name, status)
        VALUES (#{username}, #{password}, #{realName}, #{status})
    </insert>

    <update id="update">
        UPDATE sys_user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE pk_user = #{pkUser}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_user WHERE pk_user = #{pkUser}
    </delete>

    <update id="updateStatus">
        UPDATE sys_user SET status = #{status} WHERE pk_user = #{pkUser}
    </update>
</mapper>
